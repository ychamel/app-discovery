# Environment configuration for identity-accounts.
# Copy to `.env` for local development. Real environments set these via the
# platform, not a file. Existing environment variables always override the file.

# --- Core ---
# DEBUG must be false in production (enables HTTPS/secure-cookie enforcement).
DJANGO_DEBUG=true
# Required when DJANGO_DEBUG=false. Generate a long random value.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated, scheme-qualified HTTPS origins trusted for CSRF behind a TLS proxy
# (Django 4+). Required in production, e.g. https://your-app.onrender.com. Empty locally.
CSRF_TRUSTED_ORIGINS=

# --- Database (PostgreSQL; citext + UUID require it) ---
# A single DATABASE_URL (postgres://USER:PASSWORD@HOST:PORT/NAME), as managed hosts hand out.
# When set it OVERRIDES the discrete DB_* vars below; leave unset for local dev.
DATABASE_URL=
DB_NAME=identity
DB_USER=postgres
DB_PASSWORD=
# A hostname, or an absolute directory path for a local unix socket.
DB_HOST=localhost
DB_PORT=5432

# --- Email (pluggable transport; console backend prints links in dev) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@app-discovery.local
# Absolute base URL used to build magic-link URLs in emails.
PUBLIC_BASE_URL=http://localhost:8000
# SMTP transport — used ONLY when EMAIL_BACKEND is the SMTP backend (the console default
# ignores these). Defaults mirror Django's own, so leaving them unset is identical to
# vanilla Django. In production point at a real provider (Resend) and set
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend.
# See docs/deploy/email-provider-setup.md for the full setup.
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false

# --- Application tunables (apps.core.config; positive integers) ---
# Magic-link token lifetime, in seconds (default 900 = 15 minutes).
LOGIN_TOKEN_TTL_SECONDS=900
# Auth-request rate limits (per hour).
RATE_LIMIT_PER_EMAIL_PER_HOUR=5
RATE_LIMIT_PER_IP_PER_HOUR=20
# Max replaced_by successor hops resolve_tag follows before treating the chain as a
# cycle (interest-taxonomy; default 16).
TAXONOMY_RESOLVE_MAX_STEPS=16
# App-catalog screenshot limits (submission-intake; the contract app-pages adopts).
CATALOG_MEDIA_MAX_COUNT=8
CATALOG_MEDIA_MAX_BYTES=5242880
# Return-to-platform evaluation windows in days (signal-capture; the funnel derives
# returns_3d/returns_14d from these — the single source of truth, no magic 3/14 in logic).
RETURN_WINDOW_SHORT_DAYS=3
RETURN_WINDOW_LONG_DAYS=14

# --- Media storage (apps/catalog uploaded screenshots) ---
# Directory uploaded app screenshots are written to. Defaults to ./media when unset; in
# production point at a managed volume or front MEDIA_URL with an object store.
MEDIA_ROOT=

# --- Cache (rate-limit counters) ---
# Optional. When set, the default cache is Django's RedisCache at this URL, so the
# auth rate limiter holds across gunicorn workers. When unset, falls back to a
# per-process LocMemCache (fine for local dev / tests). Format: redis://host:6379/0
REDIS_URL=

# --- Error monitoring (Sentry) ---
# Optional. When set, unhandled exceptions are reported to Sentry. Unset ⇒ disabled
# (sentry_sdk is not even imported), so local dev / tests are untouched.
SENTRY_DSN=
